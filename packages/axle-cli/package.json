    "a11y-testing",
    "compliance",
    "eaa",
    "eaa-2025",
    "ada",
    "ada-compliance",
    "section-508",
    "en-301-549",
    "claude",
    "ai-fixes",
    "ci",
    "cli"
  ],
  "license": "MIT",
  "author": "axle",
  "homepage": "https://github.com/asafamos/axle",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asafamos/axle.git",
    "directory": "packages/axle-cli"
  },
  "bin": {
    "axle-cli": "./dist/axle.js",
    "axle": "./dist/axle.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
