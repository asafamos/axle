{
  "name": "axle-storybook",
  "version": "0.1.0",
  "description": "Storybook addon — runs axe-core 4.11 against every story and displays WCAG 2.2 AA violations in a Storybook panel. Same engine as axle CI, so what you see in the panel is what the GitHub Action will block on PR.",
  "license": "MIT",
  "author": "AsafAmos",
  "repository": {
    "type": "git",
    "url": "https://github.com/asafamos/axle.git",
    "directory": "packages/axle-storybook"
  },
  "homepage": "https://axle-iota.vercel.app",
  "bugs": {
    "url": "https://github.com/asafamos/axle/issues"
  },
  "keywords": [
    "storybook-addons",
    "accessibility",
    "a11y",
    "wcag",
    "wcag-aa",
    "axe-core",
    "ada"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./preview": {
      "types": "./dist/preview.d.ts",
      "import": "./dist/preview.mjs",
      "require": "./dist/preview.js"
    },
    "./manager": {
      "types": "./dist/manager.d.ts",
      "import": "./dist/manager.mjs",
      "require": "./dist/manager.js"
    },
    "./package.json": "./package.json"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/preview.ts src/manager.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts src/preview.ts src/manager.ts --format esm,cjs --dts --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "axe-core": "^4.11.3"
  },
  "peerDependencies": {
    "storybook": "^7.0.0 || ^8.0.0 || ^9.0.0"
  },
  "devDependencies": {
    "@storybook/icons": "^1.2.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "tsup": "^8.3.0",
    "typescript": "^5"
  },
  "storybook": {
    "displayName": "axle a11y / WCAG",
    "icon": "https://axle-iota.vercel.app/opengraph-image",
    "supportedFrameworks": [
      "react",
      "vue",
      "angular",
      "web-components",
      "html",
      "svelte",
      "solid",
      "preact"
    ]
  }
}
